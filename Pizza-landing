<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Akatsuki Cafe</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="style.css" />
</head>

<body>
    <div id="loader">
        <div class="spinner"></div>
    </div>

    <header class="navbar">
        <div class="container nav-container">
            <h1 class="logo"> Akatsuki Cafe</h1>

            <nav>
                <ul class="nav-links">
                    <li><a href="#home">Home</a></li>
                    <li><a href="#features">About</a></li>
                    <li><a href="#menu">Menu</a></li>
                    <li><a href="#contact">Contact</a></li>
                    <li class="cart">Cart (<span id="cart-count">0</span>)</li>
                </ul>
            </nav>
            <button id="theme-toggle">🌙</button>
        </div>
    </header>


    <section class="hero" id="home">
        <div class="container hero-container">

            <div class="hero-left">
                <h5>🔥 Hot & Fresh</h5>
                <h2>Delicious Pizza Made for You</h2>
                <p>Fresh ingredients, fast delivery, and amazing taste.</p>
                <button class="btn">Order Now</button>
            </div>

            <div class="hero-right">
                <img src="assets/images/seaford 1.png" alt="Pizza" />
            </div>

        </div>
    </section>


    <section class="menu" id="menu">
        <h2 class="section-title">Our Menu</h2>

        <div class="container card-grid">

            <div class="card">
                <img src="assets/images/pizza1.png" alt="">
                <h3>Margherita</h3>
                <p>Fresh mozzarella, tomato sauce, basil</p>
                <div class="card-bottom">
                    <span>₹199</span>
                    <button class="add-btn">+</button>
                </div>
            </div>

            <div class="card">
                <img src="assets/images/pizza2.png" alt="">
                <h3>Supreme Loaded</h3>
                <p>Cheese, pepperoni, veggies</p>
                <div class="card-bottom">
                    <span>₹279</span>
                    <button class="add-btn">+</button>
                </div>
            </div>

            <div class="card">
                <img src="assets/images/pizza3.png" alt="">
                <h3>Pepperoni Ricotta</h3>
                <p>Pepperoni, ricotta, basil</p>
                <div class="card-bottom">
                    <span>₹299</span>
                    <button class="add-btn">+</button>
                </div>
            </div>

        </div>
    </section>


    <section class="cta-section">
        <h2>Craving Something Delicious?</h2>
        <p>Order your favorite pizza now </p>
        <button class="btn">Order Now</button>
    </section>


    <footer class="footer" id="contact">
        <div class="container footer-grid">

            <div>
                <h3>Akatsuki Cafe</h3>
                <p>Fresh & delicious pizza.</p>
            </div>

            <div>
                <h4>Links</h4>
                <p>Home</p>
                <p>Menu</p>
                <p>Contact</p>
            </div>

            <div>
                <h4>Contact</h4>
                <p>India</p>
                <p>+91 6360608323</p>
            </div>

        </div>
    </footer>

    <div class="cart-modal" id="cartModal">
        <div class="cart-content">
            <span class="close-cart">&times;</span>
            <h2>Your Cart</h2>
            <div id="cart-items"></div>
            <h3>Total: ₹<span id="cart-total">0</span></h3>
        </div>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="script.js"></script>
    <!-- <script src="cart.js"></script> -->
</body>

</html>
